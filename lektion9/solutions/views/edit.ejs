<!DOCTYPE html>
<html>
<head>
  <title>Edit Note</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

  <a href="/">Go Back</a>

  <h1>Edit Note</h1>

  <form method="POST" action="/note/edit/<%= note._id %>">

    <input name="title" value="<%= note.title %>" required />

    <input name="content" value="<%= note.content %>" required />

    <button type="submit">Update</button>

  </form>

</body>
</html>